{
  "name": "aidrift-vscode",
  "displayName": "AI Drift Detector",
  "description": "Watches your AI coding chats (Claude Code, Codex) and warns when sessions drift.",
  "version": "0.0.1",
  "publisher": "aidrift",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "aidrift.login", "title": "Drift: Sign In" },
      { "command": "aidrift.logout", "title": "Drift: Sign Out" },
      { "command": "aidrift.whoami", "title": "Drift: Show Signed-In User" },
      { "command": "aidrift.acceptLastTurn", "title": "Drift: Mark Last Turn Accepted" },
      { "command": "aidrift.rejectLastTurn", "title": "Drift: Mark Last Turn Rejected" },
      { "command": "aidrift.createCheckpoint", "title": "Drift: Create Checkpoint for Active Session" },
      { "command": "aidrift.showStatus", "title": "Drift: Show Status for Active Session" },
      { "command": "aidrift.openActiveInDashboard", "title": "Drift: Open Active Session in Dashboard" },
      { "command": "aidrift.openSessionInDashboard", "title": "Drift: Open Session in Dashboard" },
      { "command": "aidrift.refreshSessions", "title": "Drift: Refresh Sessions", "icon": "$(refresh)" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aidrift",
          "title": "AI Drift",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "aidrift": [
        {
          "id": "aidrift.sessions",
          "name": "Recent Sessions"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aidrift.refreshSessions",
          "when": "view == aidrift.sessions",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "AI Drift Detector",
      "properties": {
        "aidrift.apiBaseUrl": {
          "type": "string",
          "default": "http://localhost:3331/api",
          "description": "AI Drift API base URL. Single public origin for all clients (dashboard, extension, CLI). In local dev this is the frontend container (which proxies /api/* to the api container). In SaaS deployment set this to e.g. https://aidrift.example.com/api."
        },
        "aidrift.dashboardUrl": {
          "type": "string",
          "default": "http://localhost:3331",
          "description": "Dashboard URL opened by 'Drift: Open Active Session in Dashboard'."
        },
        "aidrift.watchClaudeCode": {
          "type": "boolean",
          "default": true,
          "description": "Watch ~/.claude/projects/ for new Claude Code transcripts and auto-track them."
        },
        "aidrift.statusPollIntervalSeconds": {
          "type": "number",
          "default": 3,
          "description": "How often the status bar polls /sessions/:id/status."
        },
        "aidrift.watchCodex": {
          "type": "boolean",
          "default": false,
          "description": "Watch Codex session logs (Phase 7)."
        },
        "aidrift.driftAlertThreshold": {
          "type": "number",
          "default": 65,
          "description": "Score below which a drift alert fires."
        },
        "aidrift.autoCheckpoint": {
          "type": "boolean",
          "default": true,
          "description": "Auto-create a checkpoint on every accepted turn."
        },
        "aidrift.implicitAcceptTimeoutSeconds": {
          "type": "number",
          "default": 300,
          "description": "Seconds without a follow-up before a turn is treated as implicitly accepted."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "test": "echo 'no extension tests yet'"
  },
  "dependencies": {
    "@aidrift/core": "workspace:*",
    "chokidar": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.6.3"
  }
}
